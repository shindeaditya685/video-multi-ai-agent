# ─────────────────────────────────────────────────────────────
#  .env  —  Copy this file to .env and fill in your values
#  All keys marked (FREE) have free tiers, no credit card needed
# ─────────────────────────────────────────────────────────────

# ── LLM (FREE) ───────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ── Alternative: Google Gemini (FREE tier) ───────────────────
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ── Image Generation (FREE — no key needed) ──────────────────
# Pollinations.ai is used by default (no key required)
IMAGE_PROVIDER=pollinations   # options: pollinations | stability

# ── Stability AI (FREE tier — 25 free images/day) ────────────
# Get free key at: https://platform.stability.ai
STABILITY_API_KEY=your_stability_key_here

# ── Voice (FREE — no key needed) ─────────────────────────────
# Edge-TTS is used by default (Microsoft, no key, very natural)
VOICE_NAME=en-US-GuyNeural        # options: en-US-GuyNeural | en-US-JennyNeural | en-GB-RyanNeural
VOICE_RATE=+0%                    # speed: -20% slower | +20% faster
VOICE_PITCH=+0Hz                  # pitch: -10Hz deeper | +10Hz higher
VOICE_EMOTION_ENABLED=true        # scene-aware rate/pitch/pause variation

# ── Whisper (FREE — open source) ─────────────────────────────
WHISPER_MODEL=base                # tiny | base | small | medium | large

# ── Video settings ───────────────────────────────────────────
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=24
TRANSITION_DURATION=0.5
IMAGE_CONCURRENCY=4               # parallel AI image downloads, 1-8

# ── YouTube Upload (FREE — needs OAuth setup) ─────────────────
# See: https://developers.google.com/youtube/v3/guides/uploading_a_video
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_CATEGORY_ID=25            # 25 = News & Politics
YOUTUBE_PRIVACY=private           # private | unlisted | public

# ── FastAPI Backend ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
OUTPUT_DIR=./output
TEMP_DIR=./temp

# ── Redis (optional, for production queue) ───────────────────
REDIS_URL=redis://localhost:6379/0
